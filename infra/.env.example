# GroupBuy Environment Configuration
# Copy this file to .env and update values for your environment

# ===========================
# PostgreSQL Configuration
# ===========================
POSTGRES_USER=buytogether
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=buytogether

# ===========================
# Backend Configuration
# ===========================

# Database URL for SQLAlchemy (Docker Compose)
DATABASE_URL=postgresql+psycopg://buytogether:change_me_in_production@postgres:5432/buytogether

# Application Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_V1_PREFIX=/api/v1
PROJECT_NAME=GroupBuy API
PROJECT_DESCRIPTION=Group buying platform API
PROJECT_VERSION=1.0.0

# CORS Origins (comma-separated for Docker, JSON array for local)
# For Docker Compose: use service names
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://frontend:3000

# ===========================
# Frontend Configuration
# ===========================

# API Base URL for frontend requests
VITE_API_URL=http://localhost:8000/api/v1

# ===========================
# Redis Configuration (optional)
# ===========================
# REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=

# ===========================
# External Services (optional)
# ===========================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# SENDGRID_API_KEY=SG.xxx

# ===========================
# Logging & Monitoring
# ===========================
# SENTRY_DSN=https://...@sentry.io/...
